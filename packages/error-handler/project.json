{
  "name": "@multi-vendor-ecommerce/error-handler",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/error-handler",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/error-handler/dist",
        "main": "packages/error-handler/index.ts",
        "tsConfig": "packages/error-handler/tsconfig.json",
        "assets": []
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project packages/error-handler/tsconfig.json",
        "cwd": "."
      }
    }
  }
}
