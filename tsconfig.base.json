{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2015",
    "customConditions": ["@multi-vendor-ecommerce/source"],
    "paths": {
      "@multi-vendor-ecommerce/error-handler": ["packages/error-handler/index.ts"],
      "@multi-vendor-ecommerce/middleware": ["packages/middleware/index.ts"],
      "@multi-vendor-ecommerce/prisma": ["libs/prisma.ts"],
      "@multi-vendor-ecommerce/prisma/client": ["libs/generated/prisma/client.ts"],
      "@multi-vendor-ecommerce/prisma/generated/prisma/client": ["libs/generated/prisma/client.ts"],
      "@multi-vendor-ecommerce/libs": ["libs/prisma.ts"],
      "@multi-vendor-ecommerce/libs/generated/prisma/client": ["libs/generated/prisma/client.ts"],
      "@multi-vendor-ecommerce/redis": ["libs/redis/redis.ts"]
    }
  }
}
